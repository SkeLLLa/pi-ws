# Local pi-pipe example configuration.
# Replace placeholder values before running `mise run examples:chat`.

PI_PROVIDER=openai
PI_MODEL=gpt-4.1

# Use either provider-specific keys/base URLs or the generic PI_API_KEY/PI_BASE_URL.
OPENAI_BASE_URL=https://proxy.example.com/openai/v1
OPENAI_API_KEY=sk-

# Optional pi-pipe server settings.
PI_PIPE_HOST=127.0.0.1
PI_PIPE_PORT=8787
