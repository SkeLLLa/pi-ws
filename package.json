{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "pi-ws",
  "version": "1.0.2",
  "description": "Minimalistic extendable server exposing a local pi AI agent to the internet over WebSocket.",
  "keywords": [
    "pi",
    "ai",
    "agent",
    "websocket",
    "rpc",
    "json-rpc",
    "server"
  ],
  "homepage": "https://github.com/SkeLLLa/pi-ws/blob/master/README.md",
  "bugs": {
    "url": "https://github.com/SkeLLLa/pi-ws/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkeLLLa/pi-ws.git"
  },
  "license": "MIT",
  "author": "m03geek",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pi-ws": "dist/bin/pi-ws.js"
  },
  "directories": {
    "lib": "src",
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "pnpm run build:clean && pnpm run build:node && pnpm run build:docs && pnpm run build:format",
    "build:clean": "rm -rf dist",
    "build:docs": "rm -rf temp docs/api && api-extractor run -l && api-documenter markdown -i ./temp -o ./docs/api",
    "build:format": "pretty-quick",
    "build:node": "tsc -p tsconfig.build.json",
    "demo": "PI_WS_HOST=127.0.0.1 PI_WS_PORT=8787 PI_WS_PI_ARGS=\"--no-session\" tsx src/bin/pi-ws.ts",
    "demo:built": "PI_WS_HOST=127.0.0.1 PI_WS_PORT=8787 PI_WS_PI_ARGS=\"--no-session\" node dist/bin/pi-ws.js",
    "dev": "tsx watch src/bin/pi-ws.ts",
    "example:chat": "pnpm build && node examples/run-chat.mjs",
    "lint": "pnpm run lint:types && pnpm run lint:codestyle && pnpm run lint:packages",
    "lint:codestyle": "mkdir -p temp && eslint",
    "lint:packages": "pnpm audit --prod --audit-level=high",
    "lint:types": "tsc -p tsconfig.json",
    "release": "semantic-release",
    "start": "node dist/bin/pi-ws.js",
    "test": "pnpm run lint && pnpm run test:unit",
    "test:unit": "node --no-warnings --import tsx --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test test/** --test-coverage-exclude=test/**",
    "test:unit:local": "node --no-warnings --import tsx --test test/** --test-coverage-exclude=test/**"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.0",
    "c12": "4.0.0-beta.5",
    "dotenv": "^17.4.2",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.68.0"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.29.8",
    "@microsoft/api-extractor": "^7.57.8",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@skellla/lint-config": "^3.0.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.6.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.19.0"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "provenance": true,
    "typings": "dist/index.d.ts"
  }
}
